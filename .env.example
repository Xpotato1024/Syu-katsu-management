# App
APP_ENV=development
APP_PORT=8080

# Backend
GO_LOG_LEVEL=debug
STORAGE_BACKEND=postgres
DB_AUTO_MIGRATE=true
CORS_ALLOWED_ORIGINS=http://localhost:15173,http://localhost:5173
CORS_ALLOWED_HEADERS=Content-Type,Accept,Authorization,X-Forwarded-User,X-Forwarded-Email

# Authentication (Authelia/OIDC via reverse proxy headers)
# local | proxy_header | none
# productionでは proxy_header を推奨
AUTH_MODE=none
AUTH_PROXY_USER_HEADER=X-Forwarded-User
AUTH_PROXY_EMAIL_HEADER=X-Forwarded-Email
AUTH_DEV_USER_ID=local-dev
AUTH_DEV_USER_NAME=Local Developer
AUTH_DEV_USER_EMAIL=local@example.com
AUTH_SESSION_SECRET=dev-insecure-session-secret
AUTH_SESSION_COOKIE_NAME=skm_session
AUTH_SESSION_TTL_HOURS=24
AUTH_COOKIE_SECURE=false
AUTH_ALLOW_REGISTRATION=true

# Database (PostgreSQL)
DB_HOST=db
DB_PORT=5432
DB_NAME=syukatsu
DB_USER=syukatsu_user
DB_PASSWORD=syukatsu_password
DB_SSLMODE=disable
DB_HOST_PORT=15432

# Docker published ports (development)
BACKEND_HOST_PORT=18080
FRONTEND_HOST_PORT=15173

# Backup (PostgreSQL pg_dump)
BACKUP_OUTPUT_DIR=./backups
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=14
BACKUP_FILE_PREFIX=syukatsu

# Frontend
VITE_API_BASE_URL=/api
VITE_DEV_PROXY_TARGET=http://backend:8080
VITE_LOGOUT_URL=

# Dev seed data
DEV_SEED_PREFIX=Dev検証企業
