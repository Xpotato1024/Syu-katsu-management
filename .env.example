# App
APP_ENV=development
APP_PORT=8080

# Backend
GO_LOG_LEVEL=debug
CORS_ALLOWED_ORIGINS=http://localhost:15173,http://localhost:5173

# Database (PostgreSQL)
DB_HOST=db
DB_PORT=5432
DB_NAME=syukatsu
DB_USER=syukatsu_user
DB_PASSWORD=syukatsu_password
DB_SSLMODE=disable
DB_HOST_PORT=15432

# Docker published ports (development)
BACKEND_HOST_PORT=18080
FRONTEND_HOST_PORT=15173

# Frontend
VITE_API_BASE_URL=/api
VITE_DEV_PROXY_TARGET=http://backend:8080
