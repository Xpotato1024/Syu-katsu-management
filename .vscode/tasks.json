{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev:up",
      "type": "shell",
      "command": "docker compose up -d --build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "dev:logs",
      "type": "shell",
      "command": "docker compose logs -f --tail=200 frontend backend db",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "dev:down",
      "type": "shell",
      "command": "docker compose down -v",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
